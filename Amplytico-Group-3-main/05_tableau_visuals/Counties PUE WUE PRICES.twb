      <column caption='AE Effective Water Price ' datatype='real' name='[AE PUE * Electric Price (copy)_1705042467172355]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([AE_WUE]*[water_dollars_per_kgal])/3785.41' />
      </column>
      <column caption='AE Water Coeff of Variation' datatype='real' name='[AE Power Coeff of Variation  (copy)_5114011275784194]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='STDEV([AE PUE * Electric Price (copy)_1705042467172355]) / AVG([AE PUE * Electric Price (copy)_1705042467172355])' />
      </column>
      <column caption='WEC Effective Water Price ' datatype='real' name='[AE WUE* Electric Price (copy) (copy)_1705042467291140]' role='measure' type='quantitative'>
