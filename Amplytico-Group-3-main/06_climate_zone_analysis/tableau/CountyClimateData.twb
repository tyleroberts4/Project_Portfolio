      <column caption='Search Box Filter' datatype='boolean' name='[Calculation_1270516451057664]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([County], [Parameters].[Parameter 1])' />
      </column>
      <column caption='Final BA Climate Zone' datatype='string' name='[Calculation_5184780966572034]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL(&#10;    [BA Climate Zone (Updated)],&#10;    [BA Climate Zone]&#10;)' />
      </column>
      <column caption='Final IECC Climate Zone' datatype='string' name='[Calculation_5184780966768643]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL(&#10;    STR([IECC 2021 Climate Zone (Updated)]),&#10;    STR([IECC Climate Zone (1-8)])&#10;)' />
      </column>
      <column caption='Final Moisture Regime' datatype='string' name='[Calculation_5184780967669764]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL(&#10;    [IECC 2021 Moisture Regime (Updated)],&#10;    [IECC Moisture Regime]&#10;)' />
        <aliases>
          <alias key='%null%' value='Other' />
          <alias key='&quot;A&quot;' value='Moist' />
          <alias key='&quot;B&quot;' value='Dry' />
          <alias key='&quot;C&quot;' value='Marine' />
