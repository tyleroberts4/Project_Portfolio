      <aliases enabled='yes' />
      <column caption='Season' datatype='string' name='[Calculation_0290030807715840]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF DATEPART(&apos;month&apos;, [time]) IN (12, 1, 2) THEN &quot;Winter&quot;&#10;ELSEIF DATEPART(&apos;month&apos;, [time]) IN (3, 4, 5) THEN &quot;Spring&quot;&#10;ELSEIF DATEPART(&apos;month&apos;, [time]) IN (6, 7, 8) THEN &quot;Summer&quot;&#10;ELSE &quot;Fall&quot;&#10;END' />
      </column>
      <column caption='Moisture Zone' datatype='string' name='[Calculation_0290030811119618]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [RH_pct] &lt; 40 THEN &quot;Dry&quot;&#10;ELSEIF [RH_pct] &lt; 60 THEN &quot;Moderate&quot;&#10;ELSE &quot;Humid&quot;&#10;END' />
      </column>
      <column caption='Temp Zone' datatype='string' name='[Calculation_0290030811271171]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [T_oa_C] &lt; 10 THEN &quot;Cold&quot;&#10;ELSEIF [T_oa_C] &lt; 20 THEN &quot;Mild&quot;&#10;ELSEIF [T_oa_C] &lt; 25 THEN &quot;Warm&quot;&#10;ELSE &quot;Hot&quot;&#10;END' />
      </column>
      <column caption='P atm Pa' datatype='real' name='[P_atm_Pa]' role='measure' type='quantitative' />
      <column caption='Zone' datatype='string' name='[Path]' role='dimension' type='nominal'>
